# Deepgram API Key (Required for live audio transcription)
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# LLM API Key (Required for answering transcripts and screen capture analysis)
# Works with Gemini API, NVIDIA API, OpenAI API, Groq, OpenRouter, etc.
LLM_API_KEY=your_llm_api_key_here

# LLM API URL (Base URL of the OpenAI-compatible endpoint)
# Gemini: https://generativelanguage.googleapis.com/v1beta/
# NVIDIA: https://integrate.api.nvidia.com/v1
# OpenAI: https://api.openai.com/v1
LLM_API_URL=https://generativelanguage.googleapis.com/v1beta/

# LLM Model (The default model to use for transcription answers)
LLM_MODEL=gemini-2.5-flash

# LLM Vision Model (Optional - falls back to LLM_MODEL if left blank)
# Select a vision-capable model if your main LLM model does not support image inputs.
LLM_VISION_MODEL=gemini-1.5-pro
